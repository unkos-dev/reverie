# --- Database ---
# Ports: docker-compose.yml maps postgres to host port 5433.
# Coder workspaces with a shared postgres on 5432 can use that port instead.

# Web application runtime (RLS enforced, user-scoped read filtering)
DATABASE_URL=postgres://reverie_app:reverie_app@localhost:5433/reverie_dev

# Background ingestion pipeline (permissive RLS, scoped table access)
# Used by the ingestion/enrichment workers (Steps 4-8).
# DATABASE_URL_INGESTION=postgres://reverie_ingestion:reverie_ingestion@localhost:5433/reverie_dev

# Migrations — schema owner, bypasses RLS. DO NOT use for application runtime.
# Run migrations explicitly: cd backend && DATABASE_URL=postgres://reverie:reverie@localhost:5433/reverie_dev sqlx migrate run
# DATABASE_URL_MIGRATIONS=postgres://reverie:reverie@localhost:5433/reverie_dev

# --- Paths ---
# REVERIE_LIBRARY_PATH=./library
# Also used by dev/seed-library.sh as the directory it seeds with
# Standard Ebooks fixtures, so seed + scan agree on a single path.
# REVERIE_INGESTION_PATH=./ingestion
# REVERIE_QUARANTINE_PATH=./quarantine

# --- Ingestion Pipeline ---
# Comma-separated format priority (highest first). Default: epub,pdf,mobi,azw3,cbz,cbr
# REVERIE_FORMAT_PRIORITY=epub,pdf,mobi,azw3,cbz,cbr

# What to delete from the ingestion directory after a successful batch.
#   all      — delete all files (including non-selected formats) [default]
#   ingested — delete only files that were actually ingested
#   none     — never delete source files (manual cleanup)
# REVERIE_CLEANUP_MODE=all

# --- Authentication (OIDC) ---
OIDC_ISSUER_URL=https://auth.example.com/application/o/reverie/
OIDC_CLIENT_ID=reverie
OIDC_CLIENT_SECRET=your-client-secret-here
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Metadata Enrichment Pipeline (Step 7) ---
# Toggle the enrichment queue worker. When disabled, ingested manifestations
# still land in enrichment_status='pending' but are never claimed.
# REVERIE_ENRICHMENT_ENABLED=true

# Max concurrent per-manifestation enrichment runs. Range 1–10.
# REVERIE_ENRICHMENT_CONCURRENCY=2

# Queue poll cadence (seconds) when there is nothing to claim.
# REVERIE_ENRICHMENT_POLL_IDLE_SECS=30

# Wall-clock budget for the parallel fan-out to all enabled sources.
# REVERIE_ENRICHMENT_FETCH_BUDGET_SECS=15

# Per-provider HTTP timeout (seconds).
# REVERIE_ENRICHMENT_HTTP_TIMEOUT_SECS=10

# Maximum retry attempts before a manifestation is marked 'skipped'.
# REVERIE_ENRICHMENT_MAX_ATTEMPTS=10

# Per-kind TTLs for api_cache rows.
# REVERIE_ENRICHMENT_CACHE_TTL_HIT_DAYS=30
# REVERIE_ENRICHMENT_CACHE_TTL_MISS_DAYS=7
# REVERIE_ENRICHMENT_CACHE_TTL_ERROR_MINS=15

# --- Cover Download Pipeline ---
# Hard byte cap per cover download; streaming abort mid-body on overrun.
# REVERIE_COVER_MAX_BYTES=10485760

# Total download timeout (seconds).
# REVERIE_COVER_DOWNLOAD_TIMEOUT_SECS=30

# Minimum long-edge in pixels after decode; smaller covers are rejected.
# REVERIE_COVER_MIN_LONG_EDGE_PX=1000

# Cover download HTTP redirect hop limit (SSRF-guarded at each hop).
# REVERIE_COVER_REDIRECT_LIMIT=3

# --- Metadata Writeback Pipeline (Step 8) ---
# Toggle the writeback worker. When disabled, writeback_jobs rows accumulate
# in 'pending' but are never claimed.
# REVERIE_WRITEBACK_ENABLED=true

# Max concurrent writeback jobs (per-manifestation serialisation is enforced
# by the claim CTE regardless of this setting). Range 1–10.
# REVERIE_WRITEBACK_CONCURRENCY=2

# Queue poll cadence (seconds). Lower value makes writeback feel
# near-real-time after an accept; higher reduces idle-system CPU.
# REVERIE_WRITEBACK_POLL_IDLE_SECS=5

# Maximum retry attempts before a job is marked 'skipped' (terminal).
# REVERIE_WRITEBACK_MAX_ATTEMPTS=10

# --- Metadata Provider Endpoints ---
# Override for testing / mirrors. Leave unset to use the public endpoints.
# REVERIE_OPENLIBRARY_BASE_URL=https://openlibrary.org
# REVERIE_GOOGLEBOOKS_BASE_URL=https://www.googleapis.com/books/v1
# Google Books allows 1000 anon req/day; add a key to raise the quota.
# REVERIE_GOOGLEBOOKS_API_KEY=
# REVERIE_HARDCOVER_BASE_URL=https://api.hardcover.app/v1/graphql
# Hardcover auto-disables when this is unset.
# REVERIE_HARDCOVER_API_TOKEN=

# STRONGLY RECOMMENDED.  Operator contact (email or URL) advertised in the
# outbound `User-Agent` header.  OpenLibrary grants identified requests
# 3 req/s — three times the 1 req/s anonymous tier — so leaving this unset
# triples your enrichment runtime against OpenLibrary.  The reverie backend
# emits a startup warning if absent.
REVERIE_OPERATOR_CONTACT=you@example.com

# --- OPDS Catalog (Step 9) ---
# When enabled, mounts /opds/* behind a Basic-only extractor (username =
# user_id UUID, password = device token). Feeds and downloads emit absolute
# URLs rooted at REVERIE_PUBLIC_URL — required when OPDS is enabled.
REVERIE_OPDS_ENABLED=true
REVERIE_OPDS_PAGE_SIZE=50
REVERIE_OPDS_REALM=Reverie OPDS
REVERIE_PUBLIC_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Security headers (UNK-106)
# ---------------------------------------------------------------------------
# Absolute path to the built frontend dist directory. When set, the backend
# serves /assets/* and falls back to index.html for SPA routes. When unset,
# the backend runs API-only (dev mode — Vite serves the HTML).
# The prod Dockerfile defaults this to /srv/frontend.
REVERIE_FRONTEND_DIST_PATH=

# CSP violation-reporting endpoint. Must be absolute http(s) URL.
# When set, CSP advertises report-to + report-uri pointing here.
# Reverie does not host a reporter — operator typically points this at a log
# aggregator (Loki push API, Sentry CSP endpoint, or similar).
REVERIE_CSP_REPORT_ENDPOINT=

# Enable Strict-Transport-Security header (only safe when a TLS-terminating
# proxy sits in front of Reverie). Accepts 'true' / 'false'.
REVERIE_BEHIND_HTTPS=false

# Append '; includeSubDomains' to HSTS value.
# FOOTGUN: this locks every sibling subdomain of Reverie's host into
# HTTPS-only for max-age seconds — enable only on dedicated-apex deployments.
# Requires REVERIE_BEHIND_HTTPS=true.
REVERIE_HSTS_INCLUDE_SUBDOMAINS=false

# Append '; preload' to HSTS value. For HSTS-preload-list submission.
# Requires REVERIE_BEHIND_HTTPS=true and REVERIE_HSTS_INCLUDE_SUBDOMAINS=true.
REVERIE_HSTS_PRELOAD=false
