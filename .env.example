# --- Database ---
# Ports: docker-compose.yml maps postgres to host port 5433.
# Coder workspaces with a shared postgres on 5432 can use that port instead.

# Web application runtime (RLS enforced, user-scoped read filtering)
DATABASE_URL=postgres://tome_app:tome_app@localhost:5433/tome_dev

# Background ingestion pipeline (permissive RLS, scoped table access)
# Used by the ingestion/enrichment workers (Steps 4-8).
# DATABASE_URL_INGESTION=postgres://tome_ingestion:tome_ingestion@localhost:5433/tome_dev

# Migrations — schema owner, bypasses RLS. DO NOT use for application runtime.
# Run migrations explicitly: cd backend && DATABASE_URL=postgres://tome:tome@localhost:5433/tome_dev sqlx migrate run
# DATABASE_URL_MIGRATIONS=postgres://tome:tome@localhost:5433/tome_dev

# --- Paths ---
# TOME_LIBRARY_PATH=./library
# TOME_INGESTION_PATH=./ingestion
# TOME_QUARANTINE_PATH=./quarantine

# --- Ingestion Pipeline ---
# Comma-separated format priority (highest first). Default: epub,pdf,mobi,azw3,cbz,cbr
# TOME_FORMAT_PRIORITY=epub,pdf,mobi,azw3,cbz,cbr

# What to delete from the ingestion directory after a successful batch.
#   all      — delete all files (including non-selected formats) [default]
#   ingested — delete only files that were actually ingested
#   none     — never delete source files (manual cleanup)
# TOME_CLEANUP_MODE=all

# --- Authentication (OIDC) ---
OIDC_ISSUER_URL=https://auth.example.com/application/o/tome/
OIDC_CLIENT_ID=tome
OIDC_CLIENT_SECRET=your-client-secret-here
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
