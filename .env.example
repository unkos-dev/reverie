# --- Database ---
# Ports: docker-compose.yml maps postgres to host port 5433.
# Coder workspaces with a shared postgres on 5432 can use that port instead.

# Web application runtime (RLS enforced, user-scoped read filtering)
DATABASE_URL=postgres://tome_app:tome_app@localhost:5433/tome_dev

# Background ingestion pipeline (permissive RLS, scoped table access)
# Used by the ingestion/enrichment workers (Steps 4-8).
# DATABASE_URL_INGESTION=postgres://tome_ingestion:tome_ingestion@localhost:5433/tome_dev

# Migrations — schema owner, bypasses RLS. DO NOT use for application runtime.
# Run migrations explicitly: cd backend && DATABASE_URL=postgres://tome:tome@localhost:5433/tome_dev sqlx migrate run
# DATABASE_URL_MIGRATIONS=postgres://tome:tome@localhost:5433/tome_dev

# --- Paths ---
# TOME_LIBRARY_PATH=./library
# TOME_INGESTION_PATH=./ingestion
# TOME_QUARANTINE_PATH=./quarantine

# --- Ingestion Pipeline ---
# Comma-separated format priority (highest first). Default: epub,pdf,mobi,azw3,cbz,cbr
# TOME_FORMAT_PRIORITY=epub,pdf,mobi,azw3,cbz,cbr

# What to delete from the ingestion directory after a successful batch.
#   all      — delete all files (including non-selected formats) [default]
#   ingested — delete only files that were actually ingested
#   none     — never delete source files (manual cleanup)
# TOME_CLEANUP_MODE=all

# --- Authentication (OIDC) ---
OIDC_ISSUER_URL=https://auth.example.com/application/o/tome/
OIDC_CLIENT_ID=tome
OIDC_CLIENT_SECRET=your-client-secret-here
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# --- Metadata Enrichment Pipeline (Step 7) ---
# Toggle the enrichment queue worker. When disabled, ingested manifestations
# still land in enrichment_status='pending' but are never claimed.
# TOME_ENRICHMENT_ENABLED=true

# Max concurrent per-manifestation enrichment runs. Range 1–10.
# TOME_ENRICHMENT_CONCURRENCY=2

# Queue poll cadence (seconds) when there is nothing to claim.
# TOME_ENRICHMENT_POLL_IDLE_SECS=30

# Wall-clock budget for the parallel fan-out to all enabled sources.
# TOME_ENRICHMENT_FETCH_BUDGET_SECS=15

# Per-provider HTTP timeout (seconds).
# TOME_ENRICHMENT_HTTP_TIMEOUT_SECS=10

# Maximum retry attempts before a manifestation is marked 'skipped'.
# TOME_ENRICHMENT_MAX_ATTEMPTS=10

# Per-kind TTLs for api_cache rows.
# TOME_ENRICHMENT_CACHE_TTL_HIT_DAYS=30
# TOME_ENRICHMENT_CACHE_TTL_MISS_DAYS=7
# TOME_ENRICHMENT_CACHE_TTL_ERROR_MINS=15

# --- Cover Download Pipeline ---
# Hard byte cap per cover download; streaming abort mid-body on overrun.
# TOME_COVER_MAX_BYTES=10485760

# Total download timeout (seconds).
# TOME_COVER_DOWNLOAD_TIMEOUT_SECS=30

# Minimum long-edge in pixels after decode; smaller covers are rejected.
# TOME_COVER_MIN_LONG_EDGE_PX=1000

# Cover download HTTP redirect hop limit (SSRF-guarded at each hop).
# TOME_COVER_REDIRECT_LIMIT=3

# --- Metadata Provider Endpoints ---
# Override for testing / mirrors. Leave unset to use the public endpoints.
# TOME_OPENLIBRARY_BASE_URL=https://openlibrary.org
# TOME_GOOGLEBOOKS_BASE_URL=https://www.googleapis.com/books/v1
# Google Books allows 1000 anon req/day; add a key to raise the quota.
# TOME_GOOGLEBOOKS_API_KEY=
# TOME_HARDCOVER_BASE_URL=https://api.hardcover.app/v1/graphql
# Hardcover auto-disables when this is unset.
# TOME_HARDCOVER_API_TOKEN=
