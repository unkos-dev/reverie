# Rust
target/
**/*.rs.bk

# Node
node_modules/
dist/
.vite/

# Environment
.env
.env.*
!.env.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Claude Code runtime locks + per-user local settings
.claude/*.lock
.claude/settings.local.json

# Docs build output
docs/.astro/

# Test coverage
coverage/
*.lcov
/plans/

# Dev library seed target (populated by dev/seed-library.sh when
# REVERIE_LIBRARY_PATH is unset)
backend/tests/fixtures/library/

# Gemini CLI security scanner scratch directory (mid-run temp files;
# security_report.json persists when --json is requested)
.gemini_security/

# Playwright MCP scratch (snapshots, console logs) + agent screenshot scratch
.playwright-mcp/
d2-*.png

# graphify — commit graph.json + graph.html + GRAPH_REPORT.md so teammates
# (and fresh agent sessions) get the knowledge graph immediately on clone.
# Skip the extraction cache (regenerable, ~3MB), pipeline transients
# (.graphify_*.json), and local-only artefacts (manifest.json mtime cache,
# cost.json token tracking, machine-specific Python path).
graphify-out/cache/
graphify-out/memory/
graphify-out/.graphify_*
graphify-out/manifest.json
graphify-out/cost.json
